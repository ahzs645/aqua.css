    <h2 id="menu-bar">Menu Bar</h2>
    <p>Classic Mac menu bar with Apple logo, active app name, dropdown menus, and a right-side status cluster (volume, clock, spotlight).</p>

    <%- example(`
      <nav class="menu-bar">
        <ul>
          <li>
            <span class="menu-title menu-apple" aria-label="Apple menu">
              <img src="icon/apple.png" alt="Apple" />
            </span>
          </li>
          <li>
            <span class="menu-title active">Finder</span>
          </li>
          <li>
            <span class="menu-title">File</span>
            <ul class="menu-dropdown">
              <li>New <span class="shortcut">Cmd+N</span></li>
              <li>Open... <span class="shortcut">Cmd+O</span></li>
              <li class="separator"></li>
              <li>Save <span class="shortcut">Cmd+S</span></li>
              <li class="disabled">Save As...</li>
            </ul>
          </li>
          <li>
            <span class="menu-title">Edit</span>
            <ul class="menu-dropdown">
              <li>Undo <span class="shortcut">Cmd+Z</span></li>
              <li>Redo <span class="shortcut">Cmd+Shift+Z</span></li>
              <li class="separator"></li>
              <li>Cut <span class="shortcut">Cmd+X</span></li>
              <li>Copy <span class="shortcut">Cmd+C</span></li>
              <li>Paste <span class="shortcut">Cmd+V</span></li>
            </ul>
          </li>
          <li>
            <span class="menu-title">View</span>
            <ul class="menu-dropdown">
              <li>as Icons</li>
              <li>as List</li>
              <li>as Columns</li>
            </ul>
          </li>
          <li><span class="menu-title">Go</span></li>
          <li><span class="menu-title">Window</span></li>
          <li><span class="menu-title">Help</span></li>
        </ul>
        <div class="menu-bar-status">
          <button type="button" aria-label="Volume">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor"><path d="M155.51 24.81a8 8 0 0 0-8.42.88L77.25 80H32a16 16 0 0 0-16 16v64a16 16 0 0 0 16 16h45.25l69.84 54.31A8 8 0 0 0 160 224V32a8 8 0 0 0-4.49-7.19zM32 96h40v64H32zm112 111.64L88 164.09V91.91l56-43.55zm54-106.08a40 40 0 0 1 0 52.88 8 8 0 0 1-12-10.58 24 24 0 0 0 0-31.72 8 8 0 0 1 12-10.58zM248 128a79.9 79.9 0 0 1-20.37 53.34 8 8 0 0 1-11.92-10.67 64 64 0 0 0 0-85.33 8 8 0 1 1 11.92-10.67A79.83 79.83 0 0 1 248 128z"/></svg>
          </button>
          <span class="menu-bar-clock">Wed Mar 25 1:16 PM</span>
          <button type="button" aria-label="Search">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor"><path d="M229.66 218.34l-50.07-50.06a88.11 88.11 0 1 0-11.31 11.31l50.06 50.07a8 8 0 0 0 11.32-11.32zM40 112a72 72 0 1 1 72 72 72.08 72.08 0 0 1-72-72z"/></svg>
          </button>
        </div>
      </nav>
    `) %>

    <h3>Frosted variant</h3>
    <p>Add <code>.frosted</code> for the modern translucent + blur look.</p>

    <%- example(`
      <nav class="menu-bar frosted">
        <ul>
          <li><span class="menu-title menu-apple" aria-label="Apple menu">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 170 170" width="14" height="14" fill="currentColor"><path d="M150.37 130.25c-2.45 5.66-5.35 10.87-8.71 15.66-4.58 6.53-8.33 11.05-11.22 13.56-4.48 4.12-9.28 6.23-14.42 6.35-3.69 0-8.14-1.05-13.32-3.18-5.19-2.12-9.96-3.17-14.32-3.17-4.58 0-9.48 1.05-14.71 3.17-5.24 2.13-9.46 3.24-12.68 3.35-4.93.21-9.84-1.96-14.75-6.52-3.13-2.73-7.05-7.41-11.75-14.04-5.04-7.08-9.19-15.29-12.44-24.65-3.49-10.11-5.24-19.9-5.24-29.38 0-10.86 2.35-20.23 7.05-28.08 3.69-6.31 8.61-11.28 14.78-14.93 6.17-3.65 12.83-5.51 20.01-5.63 3.91 0 9.05 1.21 15.44 3.59 6.37 2.39 10.46 3.6 12.24 3.6 1.33 0 5.87-1.42 13.58-4.24 7.29-2.62 13.43-3.71 18.45-3.28 13.6 1.1 23.83 6.47 30.66 16.13-12.18 7.37-18.21 17.7-18.09 30.97.11 10.34 3.86 18.94 11.23 25.77 3.34 3.17 7.07 5.62 11.22 7.36-.9 2.61-1.85 5.11-2.86 7.51zM119.11 7.24c0 8.1-2.96 15.67-8.86 22.67-7.12 8.32-15.73 13.13-25.07 12.37a25.22 25.22 0 0 1-.19-3.07c0-7.78 3.39-16.1 9.41-22.91 3-3.45 6.82-6.31 11.45-8.59 4.62-2.25 9-3.49 13.12-3.71.12 1.09.14 2.18.14 3.24z"/></svg>
          </span></li>
          <li><span class="menu-title active">Safari</span></li>
          <li><span class="menu-title">File</span></li>
          <li><span class="menu-title">Edit</span></li>
          <li><span class="menu-title">View</span></li>
        </ul>
        <div class="menu-bar-status">
          <span class="menu-bar-clock">Wed Mar 25 1:16 PM</span>
        </div>
      </nav>
    `) %>

